<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0b2a4a" />
  <title>Региональные представители</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar__inner">
      <div>
        <div class="brand">ООО Б.Браун Медикал</div>
        <h1>Региональные представители</h1>
        <p>Быстрый доступ к контактам и зонам ответственности</p>
      </div>

      <div class="topbar__actions">
        <input id="searchInput" class="search" type="search" placeholder="Поиск по ФИО, региону, email..." />
        <select id="regionFilter" class="select">
          <option value="">Все регионы</option>
        </select>
      </div>
    </div>
  </header>

  <main class="container">
    <section>
      <div class="section-head">
        <h2>Представители</h2>
        <div id="resultCount" class="muted"></div>
      </div>

      <div id="cardsGrid" class="cards-grid"></div>
    </section>
  </main>

  <div id="profileModal" class="modal" aria-hidden="true">
    <div class="modal__backdrop" id="closeModal"></div>
    <div class="modal__dialog">
      <button class="modal__close" id="closeModalBtn" aria-label="Закрыть">×</button>
      <div id="profileContent"></div>
    </div>
  </div>

  <script src="data.js"></script>
  <script src="app.js"></script>
</body>
</html>
